---
import Layout from '../layouts/Layout.astro';
import { name, skills, links, communities, talks } from '../data/profile';
import { products, CATEGORY_LABELS } from '../data/products';
import { experience } from '../data/experience';
import { certifications } from '../data/certifications';

// TODO: 自己PR文・活動のハイライトの語りは実際の本文に差し替える
const featuredProductNames = ['Webエンジニアのための法務確認ガイド', 'chira-ura.net', 'unagi-tasks', 'rough-table'];
const featuredProducts = featuredProductNames
  .map((n) => products.find((p) => p.name === n))
  .filter((p): p is (typeof products)[number] => Boolean(p));

const highlightTalks = talks.slice(0, 3);
---

<Layout title="Portfolio - kouno.log" description="kounoのポートフォリオ">
  <h1>Portfolio</h1>

  <section class="pitch">
    <h2>{name}</h2>
    <p class="placeholder">
      TODO: 自己PR文をここに書く（どんなエンジニアで、何を大事にしているか）
    </p>
    <p class="placeholder">
      TODO: コミュニティ運営やカンファレンス登壇に取り組んでいる理由・想いをここに書く
    </p>
  </section>

  <section>
    <h3>制作物</h3>
    <ul class="works-list">
      {featuredProducts.map((product) => (
        <li class="work-card">
          <span class="work-category">{CATEGORY_LABELS[product.category]}</span>
          <div class="work-header">
            {product.url ? (
              <a class="work-name" href={product.url} target="_blank" rel="noopener noreferrer">
                {product.name} ↗
              </a>
            ) : (
              <span class="work-name">{product.name}</span>
            )}
          </div>
          <p class="work-desc">{product.description}</p>
          {product.tags.length > 0 && (
            <div class="tags">
              {product.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
          {product.repo && (
            <div class="work-footer">
              <a class="repo-link" href={product.repo} target="_blank" rel="noopener noreferrer">GitHub →</a>
            </div>
          )}
        </li>
      ))}
    </ul>
    <p class="more-link"><a href="/products">その他の制作物を見る →</a></p>
  </section>

  <section>
    <h3>プロジェクト経験</h3>
    {experience.length > 0 ? (
      <ul class="experience-list">
        {experience.map((item) => (
          <li class="experience-card">
            <div class="experience-header">
              <span class="experience-title">{item.title}</span>
              <span class="experience-period">{item.period}</span>
            </div>
            <p class="experience-role">{item.role}</p>
            <p class="experience-desc">{item.description}</p>
          </li>
        ))}
      </ul>
    ) : (
      <p class="placeholder">TODO: 経験したプロジェクトの内容や自身の役割を記入する</p>
    )}
  </section>

  <section>
    <h3>登壇実績（ハイライト）</h3>
    <ul class="highlight-list">
      {highlightTalks.map((talk) => (
        <li>
          <a href={talk.url} target="_blank" rel="noopener noreferrer">
            {talk.title}
          </a>
          <span class="highlight-meta">
            {talk.event} / {talk.date}
          </span>
        </li>
      ))}
    </ul>
  </section>

  <section>
    <h3>コミュニティ活動</h3>
    <ul class="communities-list">
      {communities.map((community) => (
        <li>
          <a href={community.url} target="_blank" rel="noopener noreferrer">
            {community.name}
          </a>
          <span class="community-desc">{community.description}</span>
        </li>
      ))}
    </ul>
  </section>

  <section>
    <h3>スキル・資格</h3>
    <div class="skills">
      {skills.map((skill) => (
        <span class="skill-tag">{skill}</span>
      ))}
    </div>
    <ul class="certifications-list">
      {certifications.map((cert) => (
        <li>{cert.name}</li>
      ))}
    </ul>
  </section>

  <section>
    <h3>Links</h3>
    <ul class="links-list">
      {links.map((link) => (
        <li>
          <a href={link.url} target="_blank" rel="noopener noreferrer">
            {link.name}
          </a>
        </li>
      ))}
    </ul>
  </section>
</Layout>

<style>
  h1 {
    margin-bottom: 2rem;
  }

  section {
    margin-bottom: 2rem;
  }

  .pitch h2 {
    margin-bottom: 0.5rem;
    font-size: 1.5rem;
  }

  h3 {
    margin-bottom: 1rem;
    font-size: 1.1rem;
  }

  .placeholder {
    color: var(--color-text-light);
    font-style: italic;
  }

  .pitch .placeholder {
    margin-top: 0.5rem;
  }

  /* Works */
  .works-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
  }

  .work-card {
    display: flex;
    flex-direction: column;
    padding: 1.25rem 1.4rem;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: #fff;
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }

  .work-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
    border-color: var(--color-border-dark);
  }

  .work-category {
    align-self: flex-start;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--color-primary);
    background: rgba(0, 102, 204, 0.08);
    padding: 0.15rem 0.6rem;
    border-radius: 20px;
    margin-bottom: 0.7rem;
  }

  .work-name {
    font-size: 1.05rem;
    font-weight: 700;
    text-decoration: none;
    color: var(--color-text);
  }

  .work-name:hover {
    text-decoration: underline;
  }

  .work-desc {
    margin-top: 0.6rem;
    color: #444;
    line-height: 1.7;
    font-size: 0.9rem;
    flex: 1;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.9rem;
  }

  .tag {
    background: #f0f0f0;
    padding: 0.15rem 0.55rem;
    border-radius: 20px;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .work-footer {
    margin-top: 0.9rem;
  }

  .repo-link {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--color-primary);
    text-decoration: none;
  }

  .repo-link:hover {
    text-decoration: underline;
  }

  .more-link {
    margin-top: 1rem;
    font-size: 0.9rem;
  }

  /* Experience */
  .experience-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .experience-card {
    padding: 1rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }

  .experience-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .experience-title {
    font-weight: 500;
  }

  .experience-period {
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .experience-role {
    margin-top: 0.25rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .experience-desc {
    margin-top: 0.5rem;
    font-size: 0.9rem;
  }

  /* Talks */
  .highlight-list li {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .highlight-list a {
    display: block;
    text-decoration: none;
    font-weight: 500;
  }

  .highlight-list a:hover {
    text-decoration: underline;
  }

  .highlight-meta {
    display: block;
    margin-top: 0.25rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  /* Communities */
  .communities-list li {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .communities-list a {
    font-weight: 500;
    text-decoration: none;
  }

  .communities-list a:hover {
    text-decoration: underline;
  }

  .community-desc {
    display: block;
    margin-top: 0.25rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  /* Skills & Certifications */
  .skills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-tag {
    background: #f0f0f0;
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.875rem;
  }

  .certifications-list {
    margin-top: 1rem;
  }

  .certifications-list li {
    padding: 0.375rem 0;
    font-size: 0.9rem;
  }

  .certifications-list li::before {
    content: '✓ ';
    color: var(--color-primary);
  }

  /* Links */
  .links-list li {
    padding: 0.5rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .links-list a {
    text-decoration: none;
  }

  .links-list a:hover {
    text-decoration: underline;
  }
</style>
