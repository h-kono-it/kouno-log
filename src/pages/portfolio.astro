---
import Layout from '../layouts/Layout.astro';
import { name, skills, links, communities, talks, publications } from '../data/profile';
import { products, CATEGORY_LABELS } from '../data/products';
import { experience } from '../data/experience';
import { certifications } from '../data/certifications';

const featuredProductNames = ['Webエンジニアのための法務確認ガイド', 'chira-ura.net', 'unagi-tasks', 'rough-table'];
const featuredProducts = featuredProductNames
  .map((n) => products.find((p) => p.name === n))
  .filter((p): p is (typeof products)[number] => Boolean(p));

const highlightTalks = talks.slice(0, 3);

const experienceByCompany = experience.reduce<Record<string, typeof experience>>((acc, item) => {
  (acc[item.company] ??= []).push(item);
  return acc;
}, {});

const tocItems = [
  { href: '#works', label: '制作物' },
  { href: '#experience', label: 'プロジェクト経験' },
  { href: '#talks', label: '登壇実績（ハイライト）' },
  ...(publications.length > 0 ? [{ href: '#publications', label: '執筆・寄稿実績' }] : []),
  { href: '#pr', label: '自己PR' },
  { href: '#communities', label: 'コミュニティ活動' },
  { href: '#skills', label: 'スキル・資格' },
  { href: '#links', label: 'Links' },
];
---

<Layout title="Portfolio - kouno.log" description="kounoのポートフォリオ">
  <h1>Portfolio</h1>

  <section class="pitch">
    <h2>{name}</h2>
    <p>
      Webエンジニアとして10年以上の経験を持ち、技術とビジネスの双方から組織を牽引するテックリード兼エンジニアリングマネージャー。
    </p>
    <dl class="pitch-facts">
      <div>
        <dt>得意な技術領域</dt>
        <dd>Java, Kotlin, Ruby を中心としたWebアプリケーション開発</dd>
      </div>
      <div>
        <dt>確かな実績</dt>
        <dd>大手SIerにおけるミッションクリティカルな大規模案件の経験</dd>
      </div>
      <div>
        <dt>現在の役割</dt>
        <dd>技術的な意思決定に加え、事業成長を見据えたエンジニアリングマネジメントの推進</dd>
      </div>
    </dl>
  </section>

  <nav class="toc" aria-labelledby="toc-heading">
    <h3 id="toc-heading">目次</h3>
    <ol>
      {tocItems.map((item) => (
        <li><a href={item.href}>{item.label}</a></li>
      ))}
    </ol>
  </nav>

  <section id="works">
    <h3>制作物</h3>
    <ul class="works-list">
      {featuredProducts.map((product) => (
        <li class="work-card">
          <span class="work-category">{CATEGORY_LABELS[product.category]}</span>
          <div class="work-header">
            {product.url ? (
              <a class="work-name" href={product.url} target="_blank" rel="noopener noreferrer">
                {product.name} ↗
              </a>
            ) : (
              <span class="work-name">{product.name}</span>
            )}
          </div>
          <p class="work-desc">{product.description}</p>
          {product.tags.length > 0 && (
            <div class="tags">
              {product.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
          {product.repo && (
            <div class="work-footer">
              <a class="repo-link" href={product.repo} target="_blank" rel="noopener noreferrer">GitHub →</a>
            </div>
          )}
        </li>
      ))}
    </ul>
    <p class="more-link"><a href="/products">その他の制作物を見る →</a></p>
  </section>

  <section id="experience">
    <h3>プロジェクト経験</h3>
    {Object.keys(experienceByCompany).length > 0 ? (
      Object.entries(experienceByCompany).map(([company, items]) => (
        <div class="company-block">
          <h4 class="company-name">{company}</h4>
          <ul class="experience-list">
            {items.map((item) => (
              <li class="experience-card">
                <div class="experience-header">
                  <span class="experience-project">{item.project}</span>
                  <span class="experience-period">{item.period}</span>
                </div>
                <p class="experience-role">{item.role}</p>
                {item.stack.length > 0 && (
                  <div class="tags">
                    {item.stack.map((s) => (
                      <span class="tag">{s}</span>
                    ))}
                  </div>
                )}
                <ul class="experience-highlights">
                  {item.highlights.map((h) => (
                    <li>{h}</li>
                  ))}
                </ul>
              </li>
            ))}
          </ul>
        </div>
      ))
    ) : (
      <p class="placeholder">TODO: 経験したプロジェクトの内容や自身の役割を記入する</p>
    )}
  </section>

  <section id="talks">
    <h3>登壇実績（ハイライト）</h3>
    <ul class="highlight-list">
      {highlightTalks.map((talk) => (
        <li>
          <a href={talk.url} target="_blank" rel="noopener noreferrer">
            {talk.title}
          </a>
          <span class="highlight-meta">
            {talk.event} / {talk.date}
          </span>
        </li>
      ))}
    </ul>
  </section>

  {publications.length > 0 && (
    <section id="publications">
      <h3>執筆・寄稿実績</h3>
      <ul class="highlight-list">
        {publications.map((publication) => (
          <li>
            <a href={publication.url} target="_blank" rel="noopener noreferrer">
              {publication.title}
            </a>
            <span class="highlight-meta">
              {publication.publisher} / {publication.role} / {publication.date}
            </span>
          </li>
        ))}
      </ul>
    </section>
  )}

  <section id="pr">
    <h3>自己PR</h3>
    <p>できること、得意なことは大きく3つあります。</p>
    <ul class="pr-summary">
      <li>事業を加速させる技術活用力</li>
      <li>カンファレンス登壇・執筆による対外発信</li>
      <li>コミュニティ運営を通じた関係構築</li>
    </ul>

    <div class="pr-detail">
      <h4>事業を加速させる技術活用力</h4>
      <p>
        Javaエンジニアとして10年以上、大手SIerでのミッションクリティカルな案件からテックリードまで一貫して開発に携わってきました。技術を「プロジェクトを加速させる手段」と捉え、ビジネスと技術の両面から課題解決に取り組んでいます。CI/CDフローの改善によるデプロイ時間の短縮（3時間→1時間）、3ヶ月停滞していた会計処理要件の2週間での解決、生成AIを活用したコンテキストエンジニアリングの導入推進など、堅実なデリバリー力とモダンな技術スタックへの柔軟な適応力を併せ持っています。
      </p>
    </div>

    <div class="pr-detail">
      <h4>カンファレンス登壇・執筆による対外発信</h4>
      <p>
        JJUG CCCやKaigi on Railsといった大規模カンファレンスへの登壇経験、共著での商業誌掲載経験があります。
      </p>
    </div>

    <div class="pr-detail">
      <h4>コミュニティ運営を通じた関係構築</h4>
      <p>
        コミュニティ活動の原点は、自分自身が登壇や参加を通じて数多くの刺激とサポートを受けてきたことへの恩返しです。「いつか登壇したい」という目標を果たした後、今度は運営を支える側としてボランティアスタッフに関わるようになりました。地域のエンジニア同士がもっと気軽に技術を語り合える場を作りたいという思いから「東葛.dev」を立ち上げ、近隣のコミュニティとも積極的に交流しています。特定の技術に閉じず、複数言語・マネジメント・インフラ・設計など領域を横断して学び活動できることを自分の強みと捉え、それを地域コミュニティとカンファレンス双方への貢献に活かしていきたいと考えています。
      </p>
    </div>
  </section>

  <section id="communities">
    <h3>コミュニティ活動</h3>
    <ul class="communities-list">
      {communities.map((community) => (
        <li>
          <a href={community.url} target="_blank" rel="noopener noreferrer">
            {community.name}
          </a>
          <span class="community-desc">{community.description}</span>
        </li>
      ))}
    </ul>
  </section>

  <section id="skills">
    <h3>スキル・資格</h3>
    <div class="skills">
      {skills.map((skill) => (
        <span class="skill-tag">{skill}</span>
      ))}
    </div>
    <ul class="certifications-list">
      {certifications.map((cert) => (
        <li>{cert.name}</li>
      ))}
    </ul>
  </section>

  <section id="links">
    <h3>Links</h3>
    <ul class="links-list">
      {links.map((link) => (
        <li>
          <a href={link.url} target="_blank" rel="noopener noreferrer">
            {link.name}
          </a>
        </li>
      ))}
    </ul>
  </section>
</Layout>

<style>
  h1 {
    margin-bottom: 2rem;
  }

  section {
    margin-bottom: 2rem;
  }

  .pitch h2 {
    margin-bottom: 0.5rem;
    font-size: 1.5rem;
  }

  h3 {
    margin-bottom: 1rem;
    font-size: 1.1rem;
  }

  section[id] {
    scroll-margin-top: 1rem;
  }

  /* TOC */
  .toc {
    margin-bottom: 2.5rem;
    padding: 1rem 1.25rem;
    border: 1px dashed var(--color-border-dark);
    border-radius: 10px;
    background: var(--color-surface);
  }

  .toc h3 {
    margin-bottom: 0.625rem;
    font-size: 1rem;
  }

  .toc h3::before {
    content: '## ' / '';
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-weight: 600;
  }

  .toc ol {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(13rem, 1fr));
    gap: 0.375rem 1.5rem;
    list-style: decimal-leading-zero inside;
  }

  .toc li::marker {
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--color-accent);
  }

  .toc a {
    text-decoration: none;
  }

  .toc a:hover,
  .toc a:focus-visible {
    text-decoration: underline;
  }

  .placeholder {
    color: var(--color-text-light);
    font-style: italic;
  }

  .pitch-facts {
    margin-top: 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .pitch-facts div {
    display: flex;
    gap: 1rem;
    align-items: baseline;
  }

  .pitch-facts dt {
    flex: 0 0 7.5rem;
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-text-muted);
  }

  .pitch-facts dd {
    font-size: 0.95rem;
    line-height: 1.6;
  }

  @media (max-width: 480px) {
    .pitch-facts div {
      flex-direction: column;
      gap: 0.15rem;
    }

    .pitch-facts dt {
      flex: none;
    }
  }

  /* PR */
  .pr-summary {
    margin: 0.75rem 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .pr-summary li {
    font-size: 0.95rem;
    font-weight: 600;
    padding-left: 1.1rem;
    position: relative;
  }

  .pr-summary li::before {
    content: '・';
    position: absolute;
    left: 0;
    color: var(--color-primary);
  }

  .pr-detail {
    margin-top: 1.25rem;
  }

  .pr-detail h4 {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .pr-detail p {
    color: var(--color-text-muted);
    line-height: 1.7;
    font-size: 0.9rem;
  }

  /* Works */
  .works-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 1.25rem;
  }

  .work-card {
    display: flex;
    flex-direction: column;
    padding: 1.25rem 1.4rem;
    border: 1px solid var(--color-border);
    border-radius: 12px;
    background: var(--color-card);
    transition: transform 0.15s ease, box-shadow 0.15s ease, border-color 0.15s ease;
  }

  .work-card:hover {
    transform: translateY(-2px);
    box-shadow: 0 6px 18px rgba(0, 0, 0, 0.08);
    border-color: var(--color-border-dark);
  }

  .work-category {
    align-self: flex-start;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    color: var(--color-primary);
    background: light-dark(rgba(0, 102, 204, 0.08), rgba(92, 168, 255, 0.14));
    padding: 0.15rem 0.6rem;
    border-radius: 20px;
    margin-bottom: 0.7rem;
  }

  .work-name {
    font-size: 1.05rem;
    font-weight: 700;
    text-decoration: none;
    color: var(--color-text);
  }

  .work-name:hover {
    text-decoration: underline;
  }

  .work-desc {
    margin-top: 0.6rem;
    color: var(--color-text-muted);
    line-height: 1.7;
    font-size: 0.9rem;
    flex: 1;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.9rem;
  }

  .tag {
    background: var(--color-surface);
    padding: 0.15rem 0.55rem;
    border-radius: 20px;
    font-size: 0.75rem;
    color: var(--color-text-muted);
  }

  .work-footer {
    margin-top: 0.9rem;
  }

  .repo-link {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--color-primary);
    text-decoration: none;
  }

  .repo-link:hover {
    text-decoration: underline;
  }

  .more-link {
    margin-top: 1rem;
    font-size: 0.9rem;
  }

  /* Experience */
  .company-block {
    margin-bottom: 1.5rem;
  }

  .company-block:last-child {
    margin-bottom: 0;
  }

  .company-name {
    font-size: 1rem;
    font-weight: 700;
    margin-bottom: 0.75rem;
  }

  .experience-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .experience-card {
    padding: 1.1rem 1.25rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }

  .experience-header {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .experience-project {
    font-weight: 500;
  }

  .experience-period {
    font-size: 0.875rem;
    color: var(--color-text-muted);
    white-space: nowrap;
  }

  .experience-role {
    margin-top: 0.25rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .experience-highlights {
    margin-top: 0.75rem;
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }

  .experience-highlights li {
    font-size: 0.9rem;
    line-height: 1.6;
    padding-left: 1.1rem;
    position: relative;
  }

  .experience-highlights li::before {
    content: '・';
    position: absolute;
    left: 0;
    color: var(--color-text-muted);
  }

  /* Talks */
  .highlight-list li {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .highlight-list a {
    display: block;
    text-decoration: none;
    font-weight: 500;
  }

  .highlight-list a:hover {
    text-decoration: underline;
  }

  .highlight-meta {
    display: block;
    margin-top: 0.25rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  /* Communities */
  .communities-list li {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .communities-list a {
    font-weight: 500;
    text-decoration: none;
  }

  .communities-list a:hover {
    text-decoration: underline;
  }

  .community-desc {
    display: block;
    margin-top: 0.25rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  /* Skills & Certifications */
  .skills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-tag {
    background: var(--color-surface);
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.875rem;
  }

  .certifications-list {
    margin-top: 1rem;
  }

  .certifications-list li {
    padding: 0.375rem 0;
    font-size: 0.9rem;
  }

  .certifications-list li::before {
    content: '✓ ';
    color: var(--color-primary);
  }

  /* Links */
  .links-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .links-list a {
    display: inline-block;
    padding: 0.3rem 0.875rem;
    border: 1px solid var(--color-border-dark);
    border-radius: 999px;
    background: var(--color-card);
    text-decoration: none;
    font-size: 0.9rem;
    transition: border-color 0.15s, background 0.15s;
  }

  .links-list a::after {
    content: ' ↗' / '';
    color: var(--color-accent);
  }

  .links-list a:hover,
  .links-list a:focus-visible {
    border-color: var(--color-accent);
    background: var(--color-surface);
  }
</style>
