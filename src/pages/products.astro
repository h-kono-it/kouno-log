---
import Layout from '../layouts/Layout.astro';
import { products } from '../data/products';
---

<Layout title="Products - kouno.log" description="kounoが作ったプロダクト">
  <h1>Products</h1>
  <p class="lead">個人で作ったプロダクトをまとめています。</p>

  <ul class="products-list">
    {products.map((product) => (
      <li class="product-card">
        <div class="product-header">
          {product.url ? (
            <a class="product-name" href={product.url} target="_blank" rel="noopener noreferrer">
              {product.name} ↗
            </a>
          ) : (
            <span class="product-name">{product.name}</span>
          )}
        </div>
        <p class="product-desc">{product.description}</p>
        {product.tags.length > 0 && (
          <div class="tags">
            {product.tags.map((tag) => (
              <span class="tag">{tag}</span>
            ))}
          </div>
        )}
        <div class="links">
          {product.repo && (
            <a class="repo-link" href={product.repo} target="_blank" rel="noopener noreferrer">GitHub →</a>
          )}
          {product.relatedMemo && (
            <a
              class="related-memo"
              href={product.relatedMemo}
              {...(product.relatedMemo.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
            >詳細を読む →</a>
          )}
        </div>
      </li>
    ))}
  </ul>
</Layout>

<style>
  h1 {
    margin-bottom: 0.5rem;
  }

  .lead {
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  .products-list {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .product-card {
    padding: 1.25rem 1.5rem;
    border: 1px solid var(--color-border);
    border-radius: 8px;
  }

  .product-header {
    margin-bottom: 0.75rem;
  }

  .product-name {
    font-size: 1.25rem;
    font-weight: 700;
    text-decoration: none;
    color: var(--color-text);
  }

  .product-name:hover {
    text-decoration: underline;
  }

  .product-desc {
    color: #444;
    line-height: 1.7;
    margin-bottom: 0.75rem;
  }

  .tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 0.75rem;
  }

  .tag {
    background: #f0f0f0;
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
    font-size: 0.8rem;
    color: var(--color-text-muted);
  }

  .links {
    display: flex;
    gap: 1rem;
  }

  .repo-link,
  .related-memo {
    font-size: 0.875rem;
    color: var(--color-primary);
  }
</style>
