---
import Layout from '../../layouts/Layout.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import ArticleContent from '../../components/ArticleContent.astro';
import OptimizedImg from '../../components/OptimizedImg.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const news = await getCollection('news');
  return news.map((item) => ({
    params: { id: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);
const pageUrl = Astro.url.href;
---

<Layout title={`${item.data.title} | kouno.log`} description={item.data.description} ogImage={`/og/news/${item.id}.png`}>
  <article>
    <header>
      <h1>{item.data.title}</h1>
      <time datetime={item.data.pubDate.toISOString()}>
        {item.data.pubDate.toLocaleDateString('ja-JP')}
      </time>
    </header>
    <ArticleContent>
      <Content components={{ img: OptimizedImg }} />
    </ArticleContent>
    <div class="share-buttons-bottom">
      <ShareButtons title={item.data.title} url={pageUrl} showHatena={false} />
    </div>
  </article>
  <p class="back-link">
    <a href="/news">&larr; News一覧に戻る</a>
  </p>
</Layout>

<style>
  article header {
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  article h1 {
    margin-bottom: 0.5rem;
  }

  time {
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  .share-buttons-bottom {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .back-link {
    margin-top: 2rem;
  }
</style>

