---
import Layout from '../../layouts/Layout.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const memos = await getCollection('memos');
  return memos.map((memo: CollectionEntry<'memos'>) => ({
    params: { id: memo.id },
    props: { memo },
  }));
}

const { memo } = Astro.props;
const { Content } = await render(memo);
const pageUrl = Astro.url.href;
---

<Layout title={`${memo.data.title} | kouno.log`} description={memo.data.description} ogImage={`/og/memos/${memo.id}.png`}>
  <article>
    <header>
      <h1>{memo.data.title}</h1>
      <time datetime={memo.data.pubDate.toISOString()}>
        {memo.data.pubDate.toLocaleDateString('ja-JP')}
      </time>
      {
        memo.data.tags.length > 0 && (
          <div class="tags">
            {memo.data.tags.map((tag: string) => (
              <a class="tag" href={`/memos?tag=${encodeURIComponent(tag)}`}>{tag}</a>
            ))}
          </div>
        )
      }
      <div class="share-buttons-top">
        <ShareButtons title={memo.data.title} url={pageUrl} />
      </div>
      <button id="raw-toggle" class="raw-toggle" aria-pressed="false">Raw</button>
    </header>
    <div class="content" id="rendered-content">
      <Content />
    </div>
    <div id="raw-wrapper" hidden>
      <button id="copy-btn" class="copy-btn">Copy</button>
      <pre class="raw-content" id="raw-content">{memo.body}</pre>
    </div>
    <div class="share-buttons-bottom">
      <ShareButtons title={memo.data.title} url={pageUrl} />
    </div>
  </article>
  <p class="back-link">
    <a href="/memos">&larr; Memos一覧に戻る</a>
  </p>
</Layout>

<style>
  article header {
    position: relative;
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid #eee;
  }

  article h1 {
    margin-bottom: 0.5rem;
    padding-right: 4rem;
  }

  time {
    color: #666;
    font-size: 0.875rem;
  }

  .tags {
    margin-top: 0.5rem;
    display: flex;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.125rem 0.5rem;
    background: #f0f0f0;
    border-radius: 4px;
    color: #333;
    text-decoration: none;
    transition: background 0.2s;
  }

  .tag:hover {
    background: #e0e0e0;
  }

  .content {
    line-height: 1.8;
  }

  .content :global(h1),
  .content :global(h2),
  .content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .content :global(h1)::before {
    content: "# ";
    color: #999;
  }

  .content :global(h2)::before {
    content: "## ";
    color: #999;
  }

  .content :global(h3)::before {
    content: "### ";
    color: #999;
  }

  .content :global(p) {
    margin-bottom: 1rem;
  }

  .content :global(ul),
  .content :global(ol) {
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .content :global(code) {
    background: #f5f5f5;
    padding: 0.125rem 0.25rem;
    border-radius: 4px;
    }

  .content :global(pre) {
    background: #f5f5f5;
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
    margin-bottom: 1rem;
  }

  .content :global(pre code) {
    background: none;
    padding: 0;
  }

  .content :global(blockquote) {
    margin: 1rem 0;
    padding: 0.5rem 1rem;
    border-left: 4px solid #ccc;
    color: #666;
  }

  .content :global(img) {
    max-width: 100%;
    height: auto;
    border: 1px solid #999;
  }

  .content :global(table) {
    border-collapse: collapse;
    width: 100%;
    margin-bottom: 1rem;
    display: block;
    overflow-x: auto;
  }

  .content :global(th),
  .content :global(td) {
    border: none;
    padding: 0.5rem 0.75rem;
    text-align: left;
  }

  .content :global(th) {
    font-weight: 600;
  }

  .content :global(figure) {
    margin: 1rem 0;
  }

  .content :global(figcaption) {
    margin-top: 0.375rem;
    font-size: 0.8rem;
    color: #888;
    text-align: center;
  }

  .back-link {
    margin-top: 2rem;
  }

  .share-buttons-top {
    margin-top: 1rem;
  }

  .raw-toggle {
    position: absolute;
    top: 0;
    right: 0;
    padding: 0.25rem 0.625rem;
    font-size: 0.75rem;
    font-family: 'SF Mono', 'Fira Code', monospace;
    background: #f0f0f0;
    border: 1px solid #ccc;
    border-radius: 4px;
    cursor: pointer;
    color: #555;
    transition: background 0.2s, color 0.2s;
  }

  .raw-toggle:hover {
    background: #e0e0e0;
  }

  .raw-toggle[aria-pressed='true'] {
    background: #333;
    color: #fff;
    border-color: #333;
  }

  #raw-wrapper {
    position: relative;
  }

  .copy-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    padding: 0.2rem 0.5rem;
    font-size: 0.75rem;
    font-family: 'SF Mono', 'Fira Code', monospace;
    background: #fff;
    border: 1px solid #ccc;
    border-radius: 4px;
    cursor: pointer;
    color: #555;
    transition: background 0.2s, color 0.2s;
  }

  .copy-btn:hover {
    background: #e0e0e0;
  }

  .copy-btn.copied {
    background: #333;
    color: #fff;
    border-color: #333;
  }

  .raw-content {
    background: #f5f5f5;
    border-radius: 8px;
    padding: 1rem;
    overflow-x: auto;
    white-space: pre-wrap;
    word-break: break-word;
    font-size: 0.875rem;
    line-height: 1.7;
    font-family: 'SF Mono', 'Fira Code', monospace;
  }

  .share-buttons-bottom {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid #eee;
  }
</style>

<script is:inline src="https://unpkg.com/roughjs@latest/bundled/rough.js"></script>
<script is:inline src="https://unpkg.com/rough-table/rough-table.min.js"></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof RoughTable !== 'undefined') {
      document.querySelectorAll('.content table').forEach(function (table) {
        table.dataset.border = 'rows';
      });
      RoughTable.init('.content table');
    }
  });
</script>

<script>
  const toggleBtn = document.getElementById('raw-toggle') as HTMLButtonElement;
  const rendered = document.getElementById('rendered-content') as HTMLElement;
  const rawWrapper = document.getElementById('raw-wrapper') as HTMLElement;
  const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;
  const rawContent = document.getElementById('raw-content') as HTMLElement;

  toggleBtn.addEventListener('click', () => {
    const isRaw = toggleBtn.getAttribute('aria-pressed') === 'true';
    if (isRaw) {
      rendered.hidden = false;
      rawWrapper.hidden = true;
      toggleBtn.setAttribute('aria-pressed', 'false');
      toggleBtn.textContent = 'Raw';
    } else {
      rendered.hidden = true;
      rawWrapper.hidden = false;
      toggleBtn.setAttribute('aria-pressed', 'true');
      toggleBtn.textContent = 'Rendered';
    }
  });

  copyBtn.addEventListener('click', async () => {
    await navigator.clipboard.writeText(rawContent.textContent ?? '');
    copyBtn.textContent = 'Copied!';
    copyBtn.classList.add('copied');
    setTimeout(() => {
      copyBtn.textContent = 'Copy';
      copyBtn.classList.remove('copied');
    }, 2000);
  });
</script>
