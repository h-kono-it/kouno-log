---
import Layout from '../../layouts/Layout.astro';
import ShareButtons from '../../components/ShareButtons.astro';
import ArticleContent from '../../components/ArticleContent.astro';
import OptimizedImg from '../../components/OptimizedImg.astro';
import { getCollection, render, type CollectionEntry } from 'astro:content';

export async function getStaticPaths() {
  const memos = await getCollection('memos');
  return memos.map((memo: CollectionEntry<'memos'>) => ({
    params: { id: memo.id },
    props: { memo },
  }));
}

const { memo } = Astro.props;
const { Content } = await render(memo);
const pageUrl = Astro.url.href;

const articleSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: memo.data.title,
  url: pageUrl,
  datePublished: memo.data.pubDate.toISOString(),
  ...(memo.data.description ? { description: memo.data.description } : {}),
  ...(memo.data.tags.length > 0 ? { keywords: memo.data.tags } : {}),
  image: `${Astro.url.origin}/og/memos/${memo.id}.png`,
  author: {
    '@type': 'Person',
    name: 'kouno',
    url: `${Astro.url.origin}/profile`,
  },
};
---

<Layout title={`${memo.data.title} | kouno.log`} description={memo.data.description} ogImage={`/og/memos/${memo.id}.png`}>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(articleSchema)} />
  </Fragment>
  <article>
    <header>
      <h1>{memo.data.title}</h1>
      <div class="meta-row">
        <time datetime={memo.data.pubDate.toISOString()}>
          {memo.data.pubDate.toLocaleDateString('ja-JP')}
        </time>
        <button id="raw-toggle" class="raw-toggle" aria-pressed="false">Raw</button>
      </div>
      {
        memo.data.tags.length > 0 && (
          <div class="tags">
            {memo.data.tags.map((tag: string) => (
              <a class="tag" href={`/memos?tag=${encodeURIComponent(tag)}`}>{tag}</a>
            ))}
          </div>
        )
      }
      <div class="share-buttons-top">
        <ShareButtons title={memo.data.title} url={pageUrl} />
      </div>
    </header>
    <ArticleContent id="rendered-content">
      <Content components={{ img: OptimizedImg }} />
    </ArticleContent>
    <div id="raw-wrapper" hidden>
      <button id="copy-btn" class="copy-btn">Copy</button>
      <pre class="raw-content" id="raw-content">{memo.body}</pre>
    </div>
    <div class="share-buttons-bottom">
      <ShareButtons title={memo.data.title} url={pageUrl} />
    </div>
  </article>
  <p class="back-link">
    <a href="/memos">&larr; Memos一覧に戻る</a>
  </p>
</Layout>

<style>
  article header {
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  article h1 {
    margin-bottom: 0.5rem;
  }

  .meta-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  time {
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  .tags {
    margin-top: 0.5rem;
    display: flex;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.125rem 0.625rem;
    background: var(--color-surface);
    border-radius: 999px;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: background 0.2s;
  }

  .tag::before {
    content: '#' / '';
    color: var(--color-accent);
    margin-right: 0.125rem;
  }

  .tag:hover {
    background: var(--color-surface-hover);
  }

  .back-link {
    margin-top: 2rem;
  }

  .share-buttons-top {
    margin-top: 1rem;
  }

  .raw-toggle {
    flex: none;
    padding: 0.25rem 0.625rem;
    font-size: 0.75rem;
    font-family: 'SF Mono', 'Fira Code', monospace;
    background: var(--color-surface);
    border: 1px solid var(--color-border-dark);
    border-radius: 4px;
    cursor: pointer;
    color: var(--color-text-muted);
    transition: background 0.2s, color 0.2s;
  }

  .raw-toggle:hover {
    background: var(--color-surface-hover);
  }

  .raw-toggle[aria-pressed='true'] {
    background: var(--color-text);
    color: var(--color-bg);
    border-color: var(--color-text);
  }

  #raw-wrapper {
    position: relative;
  }

  .copy-btn {
    position: absolute;
    top: 0.5rem;
    right: 0.5rem;
    padding: 0.2rem 0.5rem;
    font-size: 0.75rem;
    font-family: 'SF Mono', 'Fira Code', monospace;
    background: var(--color-card);
    border: 1px solid var(--color-border-dark);
    border-radius: 4px;
    cursor: pointer;
    color: var(--color-text-muted);
    transition: background 0.2s, color 0.2s;
  }

  .copy-btn:hover {
    background: var(--color-surface-hover);
  }

  .copy-btn.copied {
    background: var(--color-text);
    color: var(--color-bg);
    border-color: var(--color-text);
  }

  .raw-content {
    background: var(--color-surface);
    border-radius: 8px;
    padding: 1rem;
    overflow-x: auto;
    white-space: pre-wrap;
    word-break: break-word;
    font-size: 0.875rem;
    line-height: 1.7;
    font-family: 'SF Mono', 'Fira Code', monospace;
  }

  .share-buttons-bottom {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }
</style>

<script>
  const toggleBtn = document.getElementById('raw-toggle') as HTMLButtonElement;
  const rendered = document.getElementById('rendered-content') as HTMLElement;
  const rawWrapper = document.getElementById('raw-wrapper') as HTMLElement;
  const copyBtn = document.getElementById('copy-btn') as HTMLButtonElement;
  const rawContent = document.getElementById('raw-content') as HTMLElement;

  toggleBtn.addEventListener('click', () => {
    const isRaw = toggleBtn.getAttribute('aria-pressed') === 'true';
    if (isRaw) {
      rendered.hidden = false;
      rawWrapper.hidden = true;
      toggleBtn.setAttribute('aria-pressed', 'false');
      toggleBtn.textContent = 'Raw';
    } else {
      rendered.hidden = true;
      rawWrapper.hidden = false;
      toggleBtn.setAttribute('aria-pressed', 'true');
      toggleBtn.textContent = 'Rendered';
    }
  });

  copyBtn.addEventListener('click', async () => {
    await navigator.clipboard.writeText(rawContent.textContent ?? '');
    copyBtn.textContent = 'Copied!';
    copyBtn.classList.add('copied');
    setTimeout(() => {
      copyBtn.textContent = 'Copy';
      copyBtn.classList.remove('copied');
    }, 2000);
  });
</script>
