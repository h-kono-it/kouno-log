---
import Layout from '../layouts/Layout.astro';
import ShareButtons from '../components/ShareButtons.astro';
import CliTerminal from '../components/CliTerminal.astro';
import { getCollection } from 'astro:content';

const pageUrl = Astro.url.href;

const memos = await getCollection('memos', ({ data }) => !data.draft);
const news = await getCollection('news', ({ data }) => !data.draft);
const external = await getCollection('external');

// 全てのコンテンツを日付順にソート
const allContent = [
  ...memos.map((m) => ({
    type: 'memo' as const,
    title: m.data.title,
    url: `/memos/${m.id}`,
    pubDate: m.data.pubDate,
    source: 'memo' as const,
  })),
  ...news.map((n) => ({
    type: 'news' as const,
    title: n.data.title,
    url: `/news/${n.id}`,
    pubDate: n.data.pubDate,
    source: 'news' as const,
  })),
  ...external.map((e) => ({
    type: 'external' as const,
    title: e.data.title,
    url: e.data.url,
    pubDate: e.data.pubDate,
    source: e.data.source,
  })),
].sort((a, b) => b.pubDate.getTime() - a.pubDate.getTime());

const recentContent = allContent.slice(0, 10);

// アーカイブ（news + memos のみ）
const archiveContent = [
  ...memos.map((m) => ({ url: `/memos/${m.id}`, title: m.data.title, pubDate: m.data.pubDate, source: 'memo' as const })),
  ...news.map((n) => ({ url: `/news/${n.id}`, title: n.data.title, pubDate: n.data.pubDate, source: 'news' as const })),
].sort((a, b) => b.pubDate.getTime() - a.pubDate.getTime());

type MonthMap = Record<number, { count: number; items: typeof archiveContent }>;
type YearMap = Record<number, MonthMap>;

const archiveByYear = archiveContent.reduce<YearMap>((acc, item) => {
  const year = item.pubDate.getFullYear();
  const month = item.pubDate.getMonth() + 1;
  if (!acc[year]) acc[year] = {};
  if (!acc[year][month]) acc[year][month] = { count: 0, items: [] };
  acc[year][month].count++;
  acc[year][month].items.push(item);
  return acc;
}, {});

const archiveYears = Object.keys(archiveByYear).map(Number).sort((a, b) => b - a);

// 外部リンク（追加する場合はここに追加）
const links = [
  {
    name: 'GitHub',
    url: 'https://github.com/h-kono-it',
    description: 'コード',
  },
  {
    name: 'Twitter',
    url: 'https://x.com/hk_it7',
    description: 'つぶやき',
  },
  {
    name: 'Cosense',
    url: 'https://scrapbox.io/kouno-sense/',
    description: 'メモ・ナレッジベース',
  },
];
---

<Layout title="kouno.log">
  <h1>kouno.log</h1>
  <p>note、はてなブログ、ドクセルの記事とメモをまとめています。</p>

  <section>
    <h2>Recent</h2>
    <ul class="content-list">
      {
        recentContent.map((item) => (
          <li>
            <span class="badge" data-source={item.source}>
              {item.source}
            </span>
            <a href={item.url} target={item.type === 'external' ? '_blank' : undefined}>
              {item.title}
            </a>
            <time datetime={item.pubDate.toISOString()}>
              {item.pubDate.toLocaleDateString('ja-JP')}
            </time>
          </li>
        ))
      }
    </ul>
  </section>

  <a class="events-banner" href="/events">イベント参加スケジュール →</a>

  <section class="archive-section">
    <h2>Archive</h2>
    {archiveYears.map((year) => (
      <details open={year === archiveYears[0]}>
        <summary class="archive-year">{year}年</summary>
        <ul class="archive-months">
          {Object.keys(archiveByYear[year]).map(Number).sort((a, b) => b - a).map((month) => (
            <li>
              <a href={`/archive#${year}-${String(month).padStart(2, '0')}`}>
                {month}月
                <span class="archive-count">{archiveByYear[year][month].count}件</span>
              </a>
            </li>
          ))}
        </ul>
      </details>
    ))}
  </section>

  <CliTerminal />

  <section class="links-section">
    <h2>Links</h2>
    <div class="links-grid">
      {links.map((link) => (
        <a class="link-card" href={link.url} target="_blank" rel="noopener noreferrer">
          <span class="link-name">{link.name}</span>
          <span class="link-desc">{link.description}</span>
        </a>
      ))}
    </div>
  </section>

  <p class="games-link"><a href="/games">ゲームはこちら</a></p>

  <section class="share-section">
    <ShareButtons title="kouno.log" url={pageUrl} />
  </section>
</Layout>

<style>
  section {
    margin-top: 2rem;
  }

  h2 {
    margin-bottom: 1rem;
    font-size: 1.25rem;
  }

  .content-list {
    list-style: none;
  }

  .content-list li {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.5rem 0;
    border-bottom: 1px solid #eee;
    flex-wrap: wrap;
  }

  .badge {
    font-size: 0.75rem;
    padding: 0.125rem 0.5rem;
    border-radius: 4px;
    background: #eee;
    min-width: 60px;
    text-align: center;
  }

  @media (max-width: 480px) {
    .content-list li {
      flex-direction: column;
      align-items: flex-start;
      gap: 0.25rem;
    }

    .content-list li .badge {
      order: -1;
    }

    .content-list li time {
      font-size: 0.75rem;
    }
  }

  .badge[data-source='memo'] {
    background: #6b7280;
    color: white;
  }

  .badge[data-source='note'] {
    background: #41c9b4;
    color: white;
  }

  .badge[data-source='hatena'] {
    background: #00a4de;
    color: white;
  }

  .badge[data-source='docswell'] {
    background: #ff6b35;
    color: white;
  }

  .badge[data-source='toralab'] {
    background: #7c3aed;
    color: white;
  }

  .badge[data-source='news'] {
    background: #8b5cf6;
    color: white;
  }

  .content-list a {
    flex: 1;
  }

  time {
    color: #666;
    font-size: 0.875rem;
  }

  .links-section {
    margin-top: 3rem;
  }

  .links-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
    gap: 1rem;
  }

  .link-card {
    display: flex;
    flex-direction: column;
    padding: 1rem 1.25rem;
    border: 1px solid #eee;
    border-radius: 8px;
    text-decoration: none;
    color: inherit;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .link-card:hover {
    border-color: #ccc;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.05);
  }

  .link-name {
    font-weight: 600;
    font-size: 1rem;
    color: #333;
  }

  .link-desc {
    margin-top: 0.25rem;
    font-size: 0.875rem;
    color: #666;
  }

  .archive-section {
    margin-top: 2rem;
  }

  .archive-section details {
    border-bottom: 1px solid #eee;
  }

  .archive-year {
    padding: 0.5rem 0;
    cursor: pointer;
    font-size: 0.95rem;
    font-weight: 600;
    color: #333;
    list-style: none;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    user-select: none;
  }

  .archive-year::before {
    content: '▶';
    font-size: 0.6rem;
    color: #999;
    transition: transform 0.2s;
  }

  details[open] .archive-year::before {
    transform: rotate(90deg);
  }

  .archive-months {
    list-style: none;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding: 0.5rem 0 0.75rem 1rem;
  }

  .archive-months a {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    font-size: 0.875rem;
    color: #555;
    text-decoration: none;
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
    background: #f5f5f5;
    transition: background 0.2s;
  }

  .archive-months a:hover {
    background: #e8e8e8;
  }

  .archive-count {
    font-size: 0.75rem;
    color: #999;
  }

  .events-banner {
    display: block;
    margin-top: 2rem;
    padding: 0.875rem 1.25rem;
    border: 1px solid #e2e8f0;
    border-radius: 8px;
    background: #f8fafc;
    text-decoration: none;
    font-weight: 500;
    color: #334155;
    transition: border-color 0.2s, box-shadow 0.2s, background 0.2s;
  }

  .events-banner:hover {
    border-color: #94a3b8;
    background: #f1f5f9;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.06);
  }

  .games-link {
    margin-top: 2rem;
    font-size: 0.875rem;
    color: #888;
    text-align: right;
  }

  .share-section {
    margin-top: 3rem;
    padding-top: 1rem;
    border-top: 1px solid #eee;
  }
</style>
