---
import Layout from '../layouts/Layout.astro';
import { name, bio, skills, links, communities, talks, publications } from '../data/profile';

const siteUrl = Astro.url.origin;
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name,
  url: `${siteUrl}/profile`,
  image: `${siteUrl}/kouno_400x400_icon.jpg`,
  description: bio,
  sameAs: links.filter((link) => link.name !== 'Cosense').map((link) => link.url),
  alternateName: ['こうの', '河野裕隆'],
  knowsAbout: skills,
};
---

<Layout title="Profile - kouno.log" description="kounoのプロフィール">
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  </Fragment>
  <h1>Profile</h1>

  <section class="intro">
    <div class="avatar">
      <img src="/kouno_400x400_icon.jpg" alt="kouno" />
    </div>
    <div class="bio">
      <h2>{name}</h2>
      <p>{bio}</p>
    </div>
  </section>

  <section>
    <h3>Skills</h3>
    <div class="skills">
      {skills.map((skill) => (
        <span class="skill-tag">{skill}</span>
      ))}
    </div>
  </section>

  <section>
    <h3>Communities</h3>
    <ul class="communities-list">
      {communities.map((community) => (
        <li>
          <a href={community.url} target="_blank" rel="noopener noreferrer">
            {community.name}
          </a>
          <span class="community-desc">{community.description}</span>
        </li>
      ))}
    </ul>
  </section>

  {talks.length > 0 && (
    <section>
      <h3>Talks</h3>
      <ul class="talks-list">
        {talks.map((talk) => (
          <li>
            <a href={talk.url} target="_blank" rel="noopener noreferrer">
              {talk.title}
            </a>
            <span class="talk-meta">
              {talk.event} / {talk.date}
            </span>
          </li>
        ))}
      </ul>
    </section>
  )}

  {publications.length > 0 && (
    <section>
      <h3>Publications</h3>
      <ul class="publications-list">
        {publications.map((publication) => (
          <li>
            <a href={publication.url} target="_blank" rel="noopener noreferrer">
              {publication.title}
            </a>
            <span class="publication-meta">
              {publication.publisher} / {publication.role} / {publication.date}
            </span>
          </li>
        ))}
      </ul>
    </section>
  )}

  <section>
    <h3>Contact</h3>
    <p>ご連絡や登壇依頼等は <a href="https://x.com/hk_it7" target="_blank" rel="noopener noreferrer">Twitter（@hk_it7）</a>のDMまでお気軽にどうぞ。</p>
  </section>

  <section>
    <h3>Links</h3>
    <ul class="links-list">
      {links.map((link) => (
        <li>
          <a href={link.url} target="_blank" rel="noopener noreferrer">
            {link.name}
          </a>
        </li>
      ))}
    </ul>
  </section>
</Layout>

<style>
  h1 {
    margin-bottom: 2rem;
  }

  section {
    margin-bottom: 2rem;
  }

  .intro {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    margin-bottom: 2rem;
  }

  .avatar img {
    width: 100px;
    height: 100px;
    border-radius: 50%;
  }

  .bio h2 {
    margin-bottom: 0.5rem;
    font-size: 1.5rem;
  }

  .bio p {
    color: var(--color-text-muted);
  }

  h3 {
    margin-bottom: 1rem;
    font-size: 1.1rem;
  }

  section > h3::before {
    content: '### ' / '';
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-weight: 600;
  }

  .skills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .skill-tag {
    background: var(--color-surface);
    border: 1px solid var(--color-border-dark);
    padding: 0.25rem 0.75rem;
    border-radius: 20px;
    font-size: 0.875rem;
  }

  .links-list {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .links-list a {
    display: inline-block;
    padding: 0.3rem 0.875rem;
    border: 1px solid var(--color-border-dark);
    border-radius: 999px;
    background: var(--color-card);
    text-decoration: none;
    font-size: 0.9rem;
    transition: border-color 0.15s, background 0.15s;
  }

  .links-list a::after {
    content: ' ↗' / '';
    color: var(--color-accent);
  }

  .links-list a:hover,
  .links-list a:focus-visible {
    border-color: var(--color-accent);
    background: var(--color-surface);
  }

  .talks-list li {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .talks-list a {
    display: block;
    text-decoration: none;
    font-weight: 500;
  }

  .talks-list a:hover {
    text-decoration: underline;
  }

  .talk-meta {
    display: block;
    margin-top: 0.25rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .publications-list li {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .publications-list a {
    display: block;
    text-decoration: none;
    font-weight: 500;
  }

  .publications-list a:hover {
    text-decoration: underline;
  }

  .publication-meta {
    display: block;
    margin-top: 0.25rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }

  .communities-list li {
    padding: 0.75rem 0;
    border-bottom: 1px solid var(--color-border);
  }

  .communities-list a {
    font-weight: 500;
    text-decoration: none;
  }

  .communities-list a:hover {
    text-decoration: underline;
  }

  .community-desc {
    display: block;
    margin-top: 0.25rem;
    font-size: 0.875rem;
    color: var(--color-text-muted);
  }
</style>
