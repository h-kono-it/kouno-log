---
interface Props {
  id?: string;
}

const { id } = Astro.props;
---

<div class="content" id={id}>
  <slot />
</div>

<style>
  .content {
    line-height: 1.8;
  }

  .content :global(h1),
  .content :global(h2),
  .content :global(h3) {
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.4;
  }

  .content :global(h1)::before {
    content: "# ";
    content: "# " / "";
    color: var(--color-accent);
    font-family: var(--font-mono);
  }

  .content :global(h2) {
    font-size: 1.4rem;
    padding-bottom: 0.375rem;
    border-bottom: 2px dashed var(--color-border-dark);
  }

  .content :global(h2)::before {
    content: "## ";
    content: "## " / "";
    color: var(--color-accent);
    font-family: var(--font-mono);
  }

  .content :global(h3)::before {
    content: "### ";
    content: "### " / "";
    color: var(--color-accent);
    opacity: 0.75;
    font-family: var(--font-mono);
  }

  .content :global(p) {
    margin-bottom: 1rem;
  }

  .content :global(strong) {
    background: linear-gradient(transparent 62%, var(--color-marker) 62%, var(--color-marker) 96%, transparent 96%);
    padding: 0 0.1em;
  }

  .content :global(a) {
    text-decoration-thickness: 1px;
  }

  .content :global(a:hover) {
    text-decoration-thickness: 2.5px;
  }

  .content :global(ul),
  .content :global(ol) {
    list-style: revert;
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .content :global(li)::marker {
    color: var(--color-accent);
    font-weight: 700;
  }

  .content :global(hr) {
    border: none;
    border-top: 2px dashed var(--color-border-dark);
    margin: 2.5rem 0;
  }

  .content :global(code) {
    background: #faf0f3;
    color: #b02458;
    border: 1px solid #f3dde5;
    padding: 0.125rem 0.375rem;
    border-radius: 4px;
    font-size: 0.9rem;
  }

  .content :global(pre) {
    background: #f5f5f5;
    padding: 1rem 1.25rem;
    border-radius: 10px;
    overflow-x: auto;
    margin-bottom: 1.5rem;
    box-shadow: 3px 3px 0 var(--color-border);
  }

  .content :global(pre code) {
    background: none;
    border: none;
    color: inherit;
    padding: 0;
  }

  .content :global(blockquote) {
    margin: 1.5rem 0;
    padding: 0.75rem 1.25rem;
    border-left: 4px solid var(--color-accent);
    border-radius: 0 8px 8px 0;
    background: #fdf3ec;
    color: var(--color-text-muted);
  }

  .content :global(blockquote p:last-child) {
    margin-bottom: 0;
  }

  .content :global(img) {
    max-width: 100%;
    height: auto;
    border: 1px solid #999;
    border-radius: 4px;
  }

  .content :global(table) {
    border-collapse: collapse;
    width: 100%;
    margin-bottom: 1rem;
    display: block;
    overflow-x: auto;
  }

  .content :global(th),
  .content :global(td) {
    border: none;
    padding: 0.5rem 0.75rem;
    text-align: left;
  }

  .content :global(th) {
    font-weight: 600;
  }

  .content :global(figure) {
    margin: 1rem 0;
  }

  .content :global(figcaption) {
    margin-top: 0.375rem;
    font-size: 0.8rem;
    color: var(--color-text-light);
    text-align: center;
  }
</style>

<script is:inline src="https://unpkg.com/roughjs@latest/bundled/rough.js"></script>
<script is:inline src="https://unpkg.com/rough-table/rough-table.min.js"></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof RoughTable !== 'undefined') {
      document.querySelectorAll('.content table').forEach(function (table) {
        table.dataset.border = 'rows';
      });
      RoughTable.init('.content table');
    }
  });
</script>
