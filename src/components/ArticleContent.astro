---
interface Props {
  id?: string;
}

const { id } = Astro.props;
---

<div class="content" id={id}>
  <slot />
</div>

<style>
  .content {
    line-height: 1.8;
  }

  .content :global(h1),
  .content :global(h2),
  .content :global(h3) {
    margin-top: 2rem;
    margin-bottom: 1rem;
  }

  .content :global(h1)::before {
    content: "# ";
    color: #999;
  }

  .content :global(h2)::before {
    content: "## ";
    color: #999;
  }

  .content :global(h3)::before {
    content: "### ";
    color: #999;
  }

  .content :global(p) {
    margin-bottom: 1rem;
  }

  .content :global(ul),
  .content :global(ol) {
    list-style: revert;
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }

  .content :global(code) {
    background: #f5f5f5;
    padding: 0.125rem 0.25rem;
    border-radius: 4px;
    font-size: 0.9rem;
  }

  .content :global(pre) {
    background: #f5f5f5;
    padding: 1rem;
    border-radius: 8px;
    overflow-x: auto;
    margin-bottom: 1rem;
  }

  .content :global(pre code) {
    background: none;
    padding: 0;
  }

  .content :global(blockquote) {
    margin: 1rem 0;
    padding: 0.5rem 1rem;
    border-left: 4px solid var(--color-border-dark);
    color: var(--color-text-muted);
  }

  .content :global(img) {
    max-width: 100%;
    height: auto;
    border: 1px solid var(--color-text-light);
  }

  .content :global(table) {
    border-collapse: collapse;
    width: 100%;
    margin-bottom: 1rem;
    display: block;
    overflow-x: auto;
  }

  .content :global(th),
  .content :global(td) {
    border: none;
    padding: 0.5rem 0.75rem;
    text-align: left;
  }

  .content :global(th) {
    font-weight: 600;
  }

  .content :global(figure) {
    margin: 1rem 0;
  }

  .content :global(figcaption) {
    margin-top: 0.375rem;
    font-size: 0.8rem;
    color: #888;
    text-align: center;
  }
</style>

<script is:inline src="https://unpkg.com/roughjs@latest/bundled/rough.js"></script>
<script is:inline src="https://unpkg.com/rough-table/rough-table.min.js"></script>
<script is:inline>
  document.addEventListener('DOMContentLoaded', function () {
    if (typeof RoughTable !== 'undefined') {
      document.querySelectorAll('.content table').forEach(function (table) {
        table.dataset.border = 'rows';
      });
      RoughTable.init('.content table');
    }
  });
</script>
