---
interface Props {
  title: string;
  url: string;
  showHatena?: boolean;
}

const { title, url, showHatena = true } = Astro.props;

const twitterUrl = `https://twitter.com/intent/tweet?text=${encodeURIComponent(`${title} | kouno.log`)}&url=${encodeURIComponent(url)}`;
const hatenaUrl = `https://b.hatena.ne.jp/entry/s/${url.replace(/^https?:\/\//, '')}`;
---

<div class="share-buttons">
  <a href={twitterUrl} target="_blank" rel="noopener noreferrer" class="share-btn twitter">
    Twitter
  </a>
  {showHatena && (
    <a href={hatenaUrl} target="_blank" rel="noopener noreferrer" class="share-btn hatena">
      はてブ
    </a>
  )}
</div>

<style>
  .share-buttons {
    display: flex;
    justify-content: flex-end;
    gap: 0.375rem;
  }

  .share-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    padding: 0.25rem 0.75rem;
    border-radius: 999px;
    font-size: 0.75rem;
    font-weight: 600;
    text-decoration: none;
    background: var(--share-bg);
    color: var(--share-fg);
    border: 1px solid transparent;
    transition: border-color 0.15s;
  }

  .share-btn::before {
    content: '';
    flex: none;
    width: 0.5em;
    height: 0.5em;
    border-radius: 50%;
    background: var(--share-dot);
  }

  .share-btn:hover,
  .share-btn:focus-visible {
    border-color: var(--share-dot);
  }

  .twitter {
    --share-dot: #1da1f2;
    --share-bg: light-dark(#e2f3fc, #14324a);
    --share-fg: light-dark(#0c5e8e, #85c8f0);
  }

  .hatena {
    --share-dot: #00a4de;
    --share-bg: light-dark(#e2f3fb, #16344a);
    --share-fg: light-dark(#015d86, #82c9ee);
  }
</style>
