---
export interface CardItem {
  id: string;
  title: string;
  description?: string;
  pubDate: Date;
  tags?: string[];
  href: string;
}

interface Props {
  items: CardItem[];
  showTags?: boolean;
  class?: string;
}

const { items, showTags = false, class: className } = Astro.props;
---

<ul class:list={["card-list", className]}>
  {
    items.map((item) => (
      <li data-tags={item.tags?.join(',')}>
        <a href={item.href}>
          <h2>{item.title}</h2>
          {item.description && <p>{item.description}</p>}
          <time datetime={item.pubDate.toISOString()}>
            {item.pubDate.toLocaleDateString('ja-JP')}
          </time>
          {showTags && item.tags && item.tags.length > 0 && (
            <div class="tags">
              {item.tags.map((tag) => (
                <span class="tag">{tag}</span>
              ))}
            </div>
          )}
        </a>
      </li>
    ))
  }
</ul>

<style>
  .card-list {
    list-style: none;
    margin-top: 2rem;
  }

  .card-list li {
    margin-bottom: 1.5rem;
  }

  .card-list li.hidden {
    display: none;
  }

  .card-list a {
    display: block;
    padding: 1rem 1.25rem;
    border: 1px solid var(--color-border-dark);
    border-radius: 10px;
    background: #fff;
    text-decoration: none;
    color: inherit;
    box-shadow: 3px 3px 0 var(--color-border);
    transition: border-color 0.15s, box-shadow 0.15s, transform 0.15s;
  }

  .card-list a:hover {
    border-color: var(--color-accent);
    box-shadow: 5px 5px 0 var(--color-marker);
    transform: translate(-2px, -2px);
  }

  .card-list h2 {
    font-size: 1.125rem;
    margin-bottom: 0.5rem;
    color: var(--color-primary);
  }

  .card-list p {
    color: var(--color-text-muted);
    margin-bottom: 0.5rem;
  }

  time {
    color: var(--color-text-light);
    font-size: 0.8rem;
    font-family: var(--font-mono);
  }

  .tags {
    margin-top: 0.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .tag {
    font-size: 0.75rem;
    padding: 0.125rem 0.625rem;
    background: var(--color-surface);
    border-radius: 999px;
    color: var(--color-text-muted);
  }

  .tag::before {
    content: '#' / '';
    color: var(--color-accent);
    margin-right: 0.125rem;
  }

  @media (max-width: 480px) {
    .card-list h2 {
      font-size: 1rem;
    }

    .card-list a {
      padding: 0.75rem;
    }
  }
</style>
