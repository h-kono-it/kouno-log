---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  src: string | ImageMetadata;
  alt: string;
  [key: string]: unknown;
}

const { src, alt, ...rest } = Astro.props;
---

{typeof src === 'object'
  ? <Image src={src} alt={alt} {...rest} />
  : <img src={src} alt={alt} {...rest} />
}
