---
import playlist from '../data/playlist.json';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'kouno.log - 技術メモとアウトプットの記録', ogImage } = Astro.props;
const siteUrl = Astro.url.origin;
const ogImageUrl = ogImage ? `${siteUrl}${ogImage}` : `${siteUrl}/ogp_kouno_log.png`;
const currentPath = Astro.url.pathname;

// footerの「今日の一曲」用。表示に使うのは title / artist のみ。
// 初期表示はビルド時にランダム選出（JS無効時のフォールバック）。
// JS有効ならページ読み込みごとにクライアント側で再抽選する。
const songs = playlist.map((s) => ({ t: s.title, a: s.artist }));
const initialSong = songs[Math.floor(Math.random() * songs.length)];
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <script is:inline>
      // FOUC防止のため、CSS適用前に保存済みテーマを反映する
      (() => {
        const theme = localStorage.getItem('color-theme');
        if (theme === 'light' || theme === 'dark') {
          document.documentElement.dataset.theme = theme;
        }
      })();
    </script>
    <meta name="google-site-verification" content="0fhS2xGI7Bvq9C2cf_sHBIB12mcQgmo9rvNbGyz5UHg" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:type" content="article" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <title>{title}</title>
    <link rel="alternate" type="application/rss+xml" title="kouno.log RSS Feed" href="/feed.xml" />
    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">メインコンテンツにスキップ</a>
    <header>
      <div class="masthead">
        <a href="/" class="site-title" aria-current={currentPath === '/' ? 'page' : undefined}>kouno<span class="site-title-log">.log</span></a>
        <div class="header-tools">
          <button id="theme-toggle" class="theme-toggle-btn">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
              <path d="M12 2a10 10 0 1 0 0 20 10 10 0 0 0 0-20zm0 2v16a8 8 0 0 1 0-16z"/>
            </svg>
            <span>テーマ: <span id="theme-label">自動</span></span>
          </button>
          <button id="ink-save-toggle" class="ink-save-btn" aria-pressed="false">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
              <path d="M5 4v3H4c-1.1 0-2 .9-2 2v7c0 1.1.9 2 2 2h1v2h14v-2h1c1.1 0 2-.9 2-2V9c0-1.1-.9-2-2-2h-1V4H5zm2 0h10v3H7V4zm-3 7c0-.55.45-1 1-1s1 .45 1 1-.45 1-1 1-1-.45-1-1zm14 7H6v-5h12v5z"/>
            </svg>
            <span class="ink-save-label-off">インクを節約</span>
            <span class="ink-save-label-on">インク節約中</span>
          </button>
        </div>
      </div>
      <nav aria-label="メインナビゲーション">
        <a href="/profile" aria-current={currentPath.startsWith('/profile') ? 'page' : undefined}>Profile</a>
        <a href="/portfolio" aria-current={currentPath.startsWith('/portfolio') ? 'page' : undefined}>Portfolio</a>
        <a href="/products" aria-current={currentPath.startsWith('/products') ? 'page' : undefined}>Products</a>
        <a href="/news" aria-current={currentPath.startsWith('/news') ? 'page' : undefined}>News</a>
        <a href="/memos" aria-current={currentPath.startsWith('/memos') ? 'page' : undefined}>Memos</a>
        <a href="/external" aria-current={currentPath.startsWith('/external') ? 'page' : undefined}>External</a>
      </nav>
    </header>
    <main id="main-content">
      <slot />
    </main>
    <footer>
      <p class="footer-bgm">
        <span class="bgm-label">🎧 今日の一曲:</span>
        <mark class="bgm-title" id="bgm-title">{initialSong.t}</mark>
        <span class="bgm-sep" aria-hidden="true">—</span>
        <span class="bgm-artist" id="bgm-artist">{initialSong.a}</span>
      </p>
      <div class="footer-meta">
        <p>&copy; {new Date().getFullYear()} kouno.log</p>
        <a href="/feed.xml" class="rss-link" aria-label="RSS Feed">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
            <circle cx="6.18" cy="17.82" r="2.18"/>
            <path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z"/>
          </svg>
        </a>
      </div>
      <script type="application/json" id="playlist-data" set:html={JSON.stringify(songs)} />
    </footer>
  </body>
</html>

<script>
  const THEME_KEY = 'color-theme';
  const THEMES = ['auto', 'light', 'dark'] as const;
  type Theme = (typeof THEMES)[number];
  const THEME_LABELS: Record<Theme, string> = { auto: '自動', light: 'ライト', dark: 'ダーク' };
  const themeToggle = document.getElementById('theme-toggle');
  const themeLabel = document.getElementById('theme-label');

  function applyTheme(mode: Theme) {
    if (mode === 'auto') {
      delete document.documentElement.dataset.theme;
      localStorage.removeItem(THEME_KEY);
    } else {
      document.documentElement.dataset.theme = mode;
      localStorage.setItem(THEME_KEY, mode);
    }
    if (themeLabel) themeLabel.textContent = THEME_LABELS[mode];
  }

  const saved = localStorage.getItem(THEME_KEY);
  let currentTheme: Theme = saved === 'light' || saved === 'dark' ? saved : 'auto';
  if (themeLabel) themeLabel.textContent = THEME_LABELS[currentTheme];

  themeToggle?.addEventListener('click', () => {
    currentTheme = THEMES[(THEMES.indexOf(currentTheme) + 1) % THEMES.length];
    applyTheme(currentTheme);
  });

  const STORAGE_KEY = 'ink-save-mode';
  const body = document.body;
  const toggle = document.getElementById('ink-save-toggle');

  function applyMode(active: boolean) {
    body.classList.toggle('ink-save-mode', active);
    if (toggle) toggle.setAttribute('aria-pressed', String(active));
  }

  applyMode(localStorage.getItem(STORAGE_KEY) === 'true');

  toggle?.addEventListener('click', () => {
    const next = !body.classList.contains('ink-save-mode');
    localStorage.setItem(STORAGE_KEY, String(next));
    applyMode(next);
  });

  // footer「今日の一曲」: 読み込みごとにプレイリストからランダムで1曲差し替える
  (() => {
    const dataEl = document.getElementById('playlist-data');
    const titleEl = document.getElementById('bgm-title');
    const artistEl = document.getElementById('bgm-artist');
    if (!dataEl?.textContent || !titleEl || !artistEl) return;
    try {
      const songs: { t: string; a: string }[] = JSON.parse(dataEl.textContent);
      if (songs.length === 0) return;
      const song = songs[Math.floor(Math.random() * songs.length)];
      titleEl.textContent = song.t;
      artistEl.textContent = song.a;
    } catch {
      // JSONが壊れていてもfooterは初期表示のままにしておく
    }
  })();
</script>

<style is:global>
  :root {
    /* light-dark() は color-scheme に応じて解決される。
       data-theme 未指定なら OS 設定に追従し、指定時はそちらを強制する */
    color-scheme: light dark;
    --color-primary: light-dark(#0066cc, #5ca8ff);
    --color-accent: light-dark(#d9480f, #ff8f57);
    --color-marker: light-dark(#ffe066, #5c4a10);
    --color-bg: light-dark(#fffcf7, #211d18);
    --color-card: light-dark(#ffffff, #2e2822);
    --color-surface: light-dark(#f6f2ea, #2b261f);
    --color-surface-hover: light-dark(#ede7db, #373128);
    --color-text: light-dark(#2b2b2b, #ece7de);
    --color-text-muted: light-dark(#5c5c5c, #b3aa9d);
    --color-text-light: light-dark(#6f6f6f, #a09788);
    --color-border: light-dark(#e8e3d8, #3a342b);
    --color-border-dark: light-dark(#cfc8bb, #554c40);
    --font-mono: 'SF Mono', 'Fira Code', 'Cascadia Code', Consolas, monospace;
    --color-badge-memo: #6b7280;
    --color-badge-note: #41c9b4;
    --color-badge-hatena: #00a4de;
    --color-badge-docswell: #ff6b35;
    --color-badge-toralab: #7c3aed;
    --color-badge-qiita: #55c500;
    --color-badge-news: #8b5cf6;
  }

  :root[data-theme='light'] {
    color-scheme: light;
  }

  :root[data-theme='dark'] {
    color-scheme: dark;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  ul {
    list-style: none;
  }

  ::selection {
    background: var(--color-marker);
    color: var(--color-text);
  }

  @media (prefers-reduced-motion: no-preference) {
    html {
      scroll-behavior: smooth;
    }
  }

  .badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-weight: 600;
    font-family: var(--font-mono);
    padding: 0.125rem 0.625rem;
    border-radius: 999px;
    text-align: center;
    background: var(--badge-bg, var(--color-surface));
    color: var(--badge-fg, var(--color-text-muted));
    border: 1px solid transparent;
  }

  .badge::before {
    content: '';
    flex: none;
    width: 0.5em;
    height: 0.5em;
    border-radius: 50%;
    background: var(--badge-dot, currentColor);
  }

  .badge[data-source='memo'] {
    --badge-dot: var(--color-badge-memo);
    --badge-bg: light-dark(#eff0f2, #343830);
    --badge-fg: light-dark(#3f4650, #c6cdd6);
  }

  .badge[data-source='note'] {
    --badge-dot: var(--color-badge-note);
    --badge-bg: light-dark(#e0f6f1, #16352e);
    --badge-fg: light-dark(#0b6455, #82dcca);
  }

  .badge[data-source='hatena'] {
    --badge-dot: var(--color-badge-hatena);
    --badge-bg: light-dark(#e2f3fb, #16344a);
    --badge-fg: light-dark(#015d86, #82c9ee);
  }

  .badge[data-source='docswell'] {
    --badge-dot: var(--color-badge-docswell);
    --badge-bg: light-dark(#ffeae1, #40281b);
    --badge-fg: light-dark(#a83c0e, #ffa77a);
  }

  .badge[data-source='toralab'] {
    --badge-dot: var(--color-badge-toralab);
    --badge-bg: light-dark(#efe9fd, #2e2547);
    --badge-fg: light-dark(#5b21b6, #c7b4f8);
  }

  .badge[data-source='qiita'] {
    --badge-dot: var(--color-badge-qiita);
    --badge-bg: light-dark(#e9f6da, #273b15);
    --badge-fg: light-dark(#33690a, #a4dc70);
  }

  .badge[data-source='news'] {
    --badge-dot: var(--color-badge-news);
    --badge-bg: light-dark(#f1ecfe, #2d2449);
    --badge-fg: light-dark(#6127c9, #c8b6f9);
  }

  .skip-link {
    position: absolute;
    top: -100%;
    left: 0;
    z-index: 100;
    padding: 0.5rem 1rem;
    background: var(--color-primary);
    color: light-dark(#fff, #0d1b2c);
    text-decoration: none;
    border-radius: 0 0 4px 0;
  }

  .skip-link:focus {
    top: 0;
  }

  :focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    border-radius: 2px;
  }

  body {
    font-family: system-ui, sans-serif;
    line-height: 1.6;
    max-width: 800px;
    margin: 0 auto;
    padding: 1rem;
    background: var(--color-bg);
    color: var(--color-text);
  }

  header {
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 2px dashed var(--color-border-dark);
  }

  .masthead {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.375rem 1rem;
    flex-wrap: wrap;
  }

  a.site-title {
    color: var(--color-text);
    text-decoration: none;
    white-space: nowrap;
    font-size: 1.5rem;
    font-weight: 700;
    font-family: var(--font-mono);
    letter-spacing: -0.5px;
  }

  .site-title-log {
    color: var(--color-accent);
  }

  a.site-title::after {
    content: '_' / '';
    /* inline-blockにすると親のtext-decoration（現在ページの下線）がカーソルに及ばない */
    display: inline-block;
    color: var(--color-accent);
    animation: cursor-blink 1.2s steps(2, start) infinite;
  }

  @keyframes cursor-blink {
    to {
      visibility: hidden;
    }
  }

  a.site-title:hover {
    opacity: 0.8;
  }

  header nav {
    display: flex;
    align-items: baseline;
    gap: 0.25rem 0.5rem;
    flex-wrap: wrap;
    margin-top: 0.625rem;
    /* リンクの左paddingぶんを相殺してタイトルと縦を揃える */
    margin-left: -0.375rem;
  }

  header nav a {
    color: var(--color-text);
    text-decoration: none;
    white-space: nowrap;
    padding: 0.125rem 0.375rem;
    border-radius: 6px;
    transition: background 0.15s;
  }

  header nav a:hover {
    background: var(--color-surface);
  }

  header nav a[aria-current="page"],
  a.site-title[aria-current="page"] {
    font-weight: 700;
    text-decoration: underline;
    text-decoration-color: var(--color-accent);
    text-decoration-thickness: 2.5px;
    text-underline-offset: 5px;
  }

  main {
    min-height: 60vh;
  }

  footer {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 2px dashed var(--color-border-dark);
    color: var(--color-text-muted);
    font-size: 0.8rem;
    font-family: var(--font-mono);
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .footer-bgm {
    display: flex;
    align-items: baseline;
    flex-wrap: wrap;
    gap: 0.15rem 0.4rem;
    min-width: 0;
  }

  .bgm-label {
    flex-shrink: 0;
  }

  .bgm-title {
    display: inline-block;
    max-width: 100%;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    vertical-align: bottom;
    /* mark 標準の黄背景は打ち消し、曲名は太字＋本文色で控えめに強調する */
    background: none;
    color: var(--color-text);
    font-weight: 600;
  }

  .bgm-sep {
    flex-shrink: 0;
    opacity: 0.6;
  }

  .bgm-artist {
    min-width: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  .footer-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .rss-link {
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .rss-link:hover {
    color: #f26522;
  }

  h1 {
    margin-bottom: 1rem;
    font-size: 1.9rem;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  main section > h2::before {
    content: '## ' / '';
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-weight: 600;
  }

  a {
    color: var(--color-primary);
    text-underline-offset: 2px;
  }

  .ink-save-btn,
  .theme-toggle-btn {
    background: none;
    border: 1px solid transparent;
    border-radius: 4px;
    cursor: pointer;
    color: var(--color-text-muted);
    font-size: 0.8rem;
    padding: 2px 6px;
    display: flex;
    align-items: center;
    gap: 4px;
    transition: color 0.2s, border-color 0.2s;
    white-space: nowrap;
  }

  .header-tools {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    margin-left: auto;
    flex-wrap: wrap;
  }

  .ink-save-btn:hover,
  .theme-toggle-btn:hover {
    color: var(--color-text);
    border-color: var(--color-border-dark);
  }

  .ink-save-btn[aria-pressed="true"] {
    color: var(--color-text);
    border-color: var(--color-text-light);
  }

  .ink-save-label-on {
    display: none;
  }

  .ink-save-btn[aria-pressed="true"] .ink-save-label-off {
    display: none;
  }

  .ink-save-btn[aria-pressed="true"] .ink-save-label-on {
    display: inline;
  }

  body.ink-save-mode {
    filter: grayscale(100%);
  }

  .filter-btn {
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-border-dark);
    border-radius: 20px;
    background: var(--color-card);
    color: var(--color-text);
    cursor: pointer;
    font-size: 0.875rem;
    transition: all 0.2s;
  }

  .filter-btn:hover {
    border-color: var(--color-accent);
  }

  .filter-btn.active {
    background: var(--color-text);
    color: var(--color-bg);
    border-color: var(--color-text);
  }

  .page-btn {
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-border-dark);
    border-radius: 4px;
    background: var(--color-card);
    color: var(--color-text);
    cursor: pointer;
    font-size: 0.875rem;
    transition: all 0.2s;
  }

  .page-btn:hover:not(:disabled) {
    border-color: var(--color-accent);
    background: var(--color-surface);
  }

  .page-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .page-info {
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation: none !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
