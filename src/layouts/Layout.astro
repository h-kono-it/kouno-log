---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'kouno.log - 技術メモとアウトプットの記録', ogImage } = Astro.props;
const siteUrl = Astro.url.origin;
const ogImageUrl = ogImage ? `${siteUrl}${ogImage}` : `${siteUrl}/ogp_kouno_log.png`;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:type" content="article" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <title>{title}</title>
    <link rel="alternate" type="application/rss+xml" title="kouno.log RSS Feed" href="/feed.xml" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">メインコンテンツにスキップ</a>
    <header>
      <nav>
        <a href="/" class="site-title" aria-current={currentPath === '/' ? 'page' : undefined}>kouno.log</a>
        <a href="/profile" aria-current={currentPath.startsWith('/profile') ? 'page' : undefined}>Profile</a>
        <a href="/products" aria-current={currentPath.startsWith('/products') ? 'page' : undefined}>Products</a>
        <a href="/news" aria-current={currentPath.startsWith('/news') ? 'page' : undefined}>News</a>
        <a href="/memos" aria-current={currentPath.startsWith('/memos') ? 'page' : undefined}>Memos</a>
        <a href="/external" aria-current={currentPath.startsWith('/external') ? 'page' : undefined}>External</a>
        <button id="ink-save-toggle" class="ink-save-btn" aria-pressed="false">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
            <path d="M5 4v3H4c-1.1 0-2 .9-2 2v7c0 1.1.9 2 2 2h1v2h14v-2h1c1.1 0 2-.9 2-2V9c0-1.1-.9-2-2-2h-1V4H5zm2 0h10v3H7V4zm-3 7c0-.55.45-1 1-1s1 .45 1 1-.45 1-1 1-1-.45-1-1zm14 7H6v-5h12v5z"/>
          </svg>
          <span class="ink-save-label-off">インクを節約する</span>
          <span class="ink-save-label-on">インク節約中</span>
        </button>
      </nav>
    </header>
    <main id="main-content">
      <slot />
    </main>
    <footer>
      <p>&copy; {new Date().getFullYear()} kouno.log</p>
      <a href="/feed.xml" class="rss-link" aria-label="RSS Feed">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
          <circle cx="6.18" cy="17.82" r="2.18"/>
          <path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z"/>
        </svg>
      </a>
    </footer>
  </body>
</html>

<script>
  const STORAGE_KEY = 'ink-save-mode';
  const body = document.body;
  const toggle = document.getElementById('ink-save-toggle');

  function applyMode(active: boolean) {
    body.classList.toggle('ink-save-mode', active);
    if (toggle) toggle.setAttribute('aria-pressed', String(active));
  }

  applyMode(localStorage.getItem(STORAGE_KEY) === 'true');

  toggle?.addEventListener('click', () => {
    const next = !body.classList.contains('ink-save-mode');
    localStorage.setItem(STORAGE_KEY, String(next));
    applyMode(next);
  });
</script>

<style is:global>
  :root {
    --color-primary: #0066cc;
    --color-text: #333;
    --color-text-muted: #666;
    --color-text-light: #999;
    --color-border: #eee;
    --color-border-dark: #ccc;
    --color-badge-note: #41c9b4;
    --color-badge-hatena: #00a4de;
    --color-badge-docswell: #ff6b35;
    --color-badge-toralab: #7c3aed;
    --color-badge-qiita: #55c500;
    --color-badge-news: #8b5cf6;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  .skip-link {
    position: absolute;
    top: -100%;
    left: 0;
    z-index: 100;
    padding: 0.5rem 1rem;
    background: var(--color-primary);
    color: #fff;
    text-decoration: none;
    border-radius: 0 0 4px 0;
  }

  .skip-link:focus {
    top: 0;
  }

  :focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    border-radius: 2px;
  }

  body {
    font-family: system-ui, sans-serif;
    line-height: 1.6;
    max-width: 800px;
    margin: 0 auto;
    padding: 1rem;
  }

  header {
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  nav {
    display: flex;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
  }

  nav a {
    color: var(--color-text);
    text-decoration: none;
    white-space: nowrap;
  }

  nav a.site-title {
    font-size: 1.5rem;
    font-weight: 700;
    font-family: 'SF Mono', 'Fira Code', 'Cascadia Code', Consolas, monospace;
    letter-spacing: -0.5px;
    margin-right: auto;
    width: 100%;
  }

  nav a.site-title:hover {
    text-decoration: none;
    opacity: 0.8;
  }

  nav a:hover {
    text-decoration: underline;
  }

  nav a[aria-current="page"] {
    font-weight: 700;
    text-decoration: underline;
  }

  @media (min-width: 480px) {
    nav a.site-title {
      width: auto;
      margin-right: 1rem;
    }
  }

  main {
    min-height: 60vh;
  }

  footer {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
    color: var(--color-text-muted);
    font-size: 0.875rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .rss-link {
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .rss-link:hover {
    color: #f26522;
  }

  h1 {
    margin-bottom: 1rem;
  }

  a {
    color: var(--color-primary);
  }

  .ink-save-btn {
    background: none;
    border: 1px solid transparent;
    border-radius: 4px;
    cursor: pointer;
    color: var(--color-text-muted);
    font-size: 0.8rem;
    padding: 2px 6px;
    display: flex;
    align-items: center;
    gap: 4px;
    transition: color 0.2s, border-color 0.2s;
    margin-left: auto;
    white-space: nowrap;
  }

  .ink-save-btn:hover {
    color: var(--color-text);
    border-color: var(--color-border-dark);
  }

  .ink-save-btn[aria-pressed="true"] {
    color: var(--color-text);
    border-color: var(--color-text-light);
  }

  .ink-save-label-on {
    display: none;
  }

  .ink-save-btn[aria-pressed="true"] .ink-save-label-off {
    display: none;
  }

  .ink-save-btn[aria-pressed="true"] .ink-save-label-on {
    display: inline;
  }

  body.ink-save-mode {
    filter: grayscale(100%);
  }

  .filter-btn {
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-border-dark);
    border-radius: 20px;
    background: white;
    cursor: pointer;
    font-size: 0.875rem;
    transition: all 0.2s;
  }

  .filter-btn:hover {
    border-color: var(--color-text-light);
  }

  .filter-btn.active {
    background: var(--color-text);
    color: white;
    border-color: var(--color-text);
  }

  .page-btn {
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-border-dark);
    border-radius: 4px;
    background: white;
    cursor: pointer;
    font-size: 0.875rem;
    transition: all 0.2s;
  }

  .page-btn:hover:not(:disabled) {
    border-color: var(--color-text-light);
    background: #f5f5f5;
  }

  .page-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .page-info {
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }
</style>
