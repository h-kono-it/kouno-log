---
interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = 'kouno.log - 技術メモとアウトプットの記録', ogImage } = Astro.props;
const siteUrl = Astro.url.origin;
const ogImageUrl = ogImage ? `${siteUrl}${ogImage}` : `${siteUrl}/ogp_kouno_log.png`;
const currentPath = Astro.url.pathname;
---

<!doctype html>
<html lang="ja">
  <head>
    <meta charset="utf-8" />
    <meta name="google-site-verification" content="0fhS2xGI7Bvq9C2cf_sHBIB12mcQgmo9rvNbGyz5UHg" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="description" content={description} />
    <meta name="generator" content={Astro.generator} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:type" content="article" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <title>{title}</title>
    <link rel="alternate" type="application/rss+xml" title="kouno.log RSS Feed" href="/feed.xml" />
    <slot name="head" />
  </head>
  <body>
    <a href="#main-content" class="skip-link">メインコンテンツにスキップ</a>
    <header>
      <nav aria-label="メインナビゲーション">
        <a href="/" class="site-title" aria-current={currentPath === '/' ? 'page' : undefined}>kouno<span class="site-title-log">.log</span></a>
        <a href="/profile" aria-current={currentPath.startsWith('/profile') ? 'page' : undefined}>Profile</a>
        <a href="/portfolio" aria-current={currentPath.startsWith('/portfolio') ? 'page' : undefined}>Portfolio</a>
        <a href="/products" aria-current={currentPath.startsWith('/products') ? 'page' : undefined}>Products</a>
        <a href="/news" aria-current={currentPath.startsWith('/news') ? 'page' : undefined}>News</a>
        <a href="/memos" aria-current={currentPath.startsWith('/memos') ? 'page' : undefined}>Memos</a>
        <a href="/external" aria-current={currentPath.startsWith('/external') ? 'page' : undefined}>External</a>
        <button id="ink-save-toggle" class="ink-save-btn" aria-pressed="false">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
            <path d="M5 4v3H4c-1.1 0-2 .9-2 2v7c0 1.1.9 2 2 2h1v2h14v-2h1c1.1 0 2-.9 2-2V9c0-1.1-.9-2-2-2h-1V4H5zm2 0h10v3H7V4zm-3 7c0-.55.45-1 1-1s1 .45 1 1-.45 1-1 1-1-.45-1-1zm14 7H6v-5h12v5z"/>
          </svg>
          <span class="ink-save-label-off">インクを節約する</span>
          <span class="ink-save-label-on">インク節約中</span>
        </button>
      </nav>
    </header>
    <main id="main-content">
      <slot />
    </main>
    <footer>
      <p>&copy; {new Date().getFullYear()} kouno.log</p>
      <a href="/feed.xml" class="rss-link" aria-label="RSS Feed">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
          <circle cx="6.18" cy="17.82" r="2.18"/>
          <path d="M4 4.44v2.83c7.03 0 12.73 5.7 12.73 12.73h2.83c0-8.59-6.97-15.56-15.56-15.56zm0 5.66v2.83c3.9 0 7.07 3.17 7.07 7.07h2.83c0-5.47-4.43-9.9-9.9-9.9z"/>
        </svg>
      </a>
    </footer>
  </body>
</html>

<script>
  const STORAGE_KEY = 'ink-save-mode';
  const body = document.body;
  const toggle = document.getElementById('ink-save-toggle');

  function applyMode(active: boolean) {
    body.classList.toggle('ink-save-mode', active);
    if (toggle) toggle.setAttribute('aria-pressed', String(active));
  }

  applyMode(localStorage.getItem(STORAGE_KEY) === 'true');

  toggle?.addEventListener('click', () => {
    const next = !body.classList.contains('ink-save-mode');
    localStorage.setItem(STORAGE_KEY, String(next));
    applyMode(next);
  });
</script>

<style is:global>
  :root {
    --color-primary: #0066cc;
    --color-accent: #d9480f;
    --color-marker: #ffe066;
    --color-bg: #fffcf7;
    --color-surface: #f6f2ea;
    --color-surface-hover: #ede7db;
    --color-text: #2b2b2b;
    --color-text-muted: #5c5c5c;
    --color-text-light: #6f6f6f;
    --color-border: #e8e3d8;
    --color-border-dark: #cfc8bb;
    --font-mono: 'SF Mono', 'Fira Code', 'Cascadia Code', Consolas, monospace;
    --color-badge-memo: #6b7280;
    --color-badge-note: #41c9b4;
    --color-badge-hatena: #00a4de;
    --color-badge-docswell: #ff6b35;
    --color-badge-toralab: #7c3aed;
    --color-badge-qiita: #55c500;
    --color-badge-news: #8b5cf6;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  ul {
    list-style: none;
  }

  ::selection {
    background: var(--color-marker);
    color: var(--color-text);
  }

  @media (prefers-reduced-motion: no-preference) {
    html {
      scroll-behavior: smooth;
    }
  }

  .badge {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.375rem;
    font-size: 0.75rem;
    font-weight: 600;
    font-family: var(--font-mono);
    padding: 0.125rem 0.625rem;
    border-radius: 999px;
    text-align: center;
    background: var(--badge-bg, var(--color-surface));
    color: var(--badge-fg, var(--color-text-muted));
    border: 1px solid transparent;
  }

  .badge::before {
    content: '';
    flex: none;
    width: 0.5em;
    height: 0.5em;
    border-radius: 50%;
    background: var(--badge-dot, currentColor);
  }

  .badge[data-source='memo'] {
    --badge-dot: var(--color-badge-memo);
    --badge-bg: #eff0f2;
    --badge-fg: #3f4650;
  }

  .badge[data-source='note'] {
    --badge-dot: var(--color-badge-note);
    --badge-bg: #e0f6f1;
    --badge-fg: #0b6455;
  }

  .badge[data-source='hatena'] {
    --badge-dot: var(--color-badge-hatena);
    --badge-bg: #e2f3fb;
    --badge-fg: #015d86;
  }

  .badge[data-source='docswell'] {
    --badge-dot: var(--color-badge-docswell);
    --badge-bg: #ffeae1;
    --badge-fg: #a83c0e;
  }

  .badge[data-source='toralab'] {
    --badge-dot: var(--color-badge-toralab);
    --badge-bg: #efe9fd;
    --badge-fg: #5b21b6;
  }

  .badge[data-source='qiita'] {
    --badge-dot: var(--color-badge-qiita);
    --badge-bg: #e9f6da;
    --badge-fg: #33690a;
  }

  .badge[data-source='news'] {
    --badge-dot: var(--color-badge-news);
    --badge-bg: #f1ecfe;
    --badge-fg: #6127c9;
  }

  .skip-link {
    position: absolute;
    top: -100%;
    left: 0;
    z-index: 100;
    padding: 0.5rem 1rem;
    background: var(--color-primary);
    color: #fff;
    text-decoration: none;
    border-radius: 0 0 4px 0;
  }

  .skip-link:focus {
    top: 0;
  }

  :focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    border-radius: 2px;
  }

  body {
    font-family: system-ui, sans-serif;
    line-height: 1.6;
    max-width: 800px;
    margin: 0 auto;
    padding: 1rem;
    background: var(--color-bg);
    color: var(--color-text);
  }

  header {
    margin-bottom: 2rem;
    padding-bottom: 1rem;
    border-bottom: 2px dashed var(--color-border-dark);
  }

  header nav {
    display: flex;
    align-items: baseline;
    gap: 0.25rem 0.75rem;
    flex-wrap: wrap;
  }

  header nav a {
    color: var(--color-text);
    text-decoration: none;
    white-space: nowrap;
    padding: 0.125rem 0.375rem;
    border-radius: 6px;
    transition: background 0.15s;
  }

  nav a.site-title {
    font-size: 1.5rem;
    font-weight: 700;
    font-family: var(--font-mono);
    letter-spacing: -0.5px;
    margin-right: auto;
    width: 100%;
    padding-left: 0;
  }

  .site-title-log {
    color: var(--color-accent);
  }

  nav a.site-title::after {
    content: '_' / '';
    /* inline-blockにすると親のtext-decoration（現在ページの下線）がカーソルに及ばない */
    display: inline-block;
    color: var(--color-accent);
    animation: cursor-blink 1.2s steps(2, start) infinite;
  }

  @keyframes cursor-blink {
    to {
      visibility: hidden;
    }
  }

  nav a.site-title:hover {
    text-decoration: none;
    background: none;
    opacity: 0.8;
  }

  header nav a:hover {
    background: var(--color-surface);
  }

  header nav a[aria-current="page"] {
    font-weight: 700;
    text-decoration: underline;
    text-decoration-color: var(--color-accent);
    text-decoration-thickness: 2.5px;
    text-underline-offset: 5px;
  }

  @media (min-width: 480px) {
    nav a.site-title {
      width: auto;
      margin-right: 1rem;
    }
  }

  main {
    min-height: 60vh;
  }

  footer {
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 2px dashed var(--color-border-dark);
    color: var(--color-text-muted);
    font-size: 0.8rem;
    font-family: var(--font-mono);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .rss-link {
    color: var(--color-text-muted);
    transition: color 0.2s;
  }

  .rss-link:hover {
    color: #f26522;
  }

  h1 {
    margin-bottom: 1rem;
    font-size: 1.9rem;
    line-height: 1.3;
    letter-spacing: -0.01em;
  }

  main section > h2::before {
    content: '## ' / '';
    color: var(--color-accent);
    font-family: var(--font-mono);
    font-weight: 600;
  }

  a {
    color: var(--color-primary);
    text-underline-offset: 2px;
  }

  .ink-save-btn {
    background: none;
    border: 1px solid transparent;
    border-radius: 4px;
    cursor: pointer;
    color: var(--color-text-muted);
    font-size: 0.8rem;
    padding: 2px 6px;
    display: flex;
    align-items: center;
    gap: 4px;
    transition: color 0.2s, border-color 0.2s;
    margin-left: auto;
    white-space: nowrap;
  }

  .ink-save-btn:hover {
    color: var(--color-text);
    border-color: var(--color-border-dark);
  }

  .ink-save-btn[aria-pressed="true"] {
    color: var(--color-text);
    border-color: var(--color-text-light);
  }

  .ink-save-label-on {
    display: none;
  }

  .ink-save-btn[aria-pressed="true"] .ink-save-label-off {
    display: none;
  }

  .ink-save-btn[aria-pressed="true"] .ink-save-label-on {
    display: inline;
  }

  body.ink-save-mode {
    filter: grayscale(100%);
  }

  .filter-btn {
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-border-dark);
    border-radius: 20px;
    background: white;
    color: var(--color-text);
    cursor: pointer;
    font-size: 0.875rem;
    transition: all 0.2s;
  }

  .filter-btn:hover {
    border-color: var(--color-accent);
  }

  .filter-btn.active {
    background: var(--color-text);
    color: white;
    border-color: var(--color-text);
  }

  .page-btn {
    padding: 0.5rem 1rem;
    border: 1px solid var(--color-border-dark);
    border-radius: 4px;
    background: white;
    color: var(--color-text);
    cursor: pointer;
    font-size: 0.875rem;
    transition: all 0.2s;
  }

  .page-btn:hover:not(:disabled) {
    border-color: var(--color-accent);
    background: var(--color-surface);
  }

  .page-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .pagination {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    margin-top: 2rem;
    padding-top: 1rem;
    border-top: 1px solid var(--color-border);
  }

  .page-info {
    color: var(--color-text-muted);
    font-size: 0.875rem;
  }

  @media (prefers-reduced-motion: reduce) {
    *,
    *::before,
    *::after {
      animation: none !important;
      transition-duration: 0.01ms !important;
    }
  }
</style>
